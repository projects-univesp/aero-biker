{
  "name": "aero-biker",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/app.js",
  "directories": {
    "doc": "docs"
  },
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --inspect src/app.ts",
    "build": "pkgroll",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "DRP04 Team",
  "license": "MIT",
  "description": "A Scalable Management System for Spinning Studios",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.6",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "tailwindcss": "^4.2.1",
    "tslog": "^4.10.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.9.7",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pkgroll": "^2.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,ts,json,hbs}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
