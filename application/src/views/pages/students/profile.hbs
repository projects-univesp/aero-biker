<div class="max-w-3xl mx-auto bg-white shadow-md rounded-lg overflow-hidden mt-8">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
        <h2 class="text-xl font-bold text-gray-800">Perfil do Aluno</h2>
        <a href="/students" class="text-blue-600 hover:text-blue-800 font-medium">&larr; Voltar para Lista</a>
    </div>
    
    <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <p class="text-sm text-gray-500 font-semibold uppercase">Nome Completo</p>
                <p class="text-lg text-gray-900">{{student.name}}</p>
            </div>
            
            <div>
                <p class="text-sm text-gray-500 font-semibold uppercase">Telefone</p>
                <p class="text-lg text-gray-900">{{student.phone}}</p>
            </div>
            
            <div>
                <p class="text-sm text-gray-500 font-semibold uppercase">Status</p>
                {{#if student.isActive}}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                        Ativo
                    </span>
                {{else}}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                        Inativo
                    </span>
                {{/if}}
            </div>
            
            <div>
                <p class="text-sm text-gray-500 font-semibold uppercase">ID do Sistema</p>
                <p class="text-sm text-gray-600 font-mono">{{student.id}}</p>
            </div>
        </div>
        
        <div class="mt-8 border-t border-gray-200 pt-6 flex gap-4">
            <a href="/students/{{student.id}}/edit" class="px-4 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600 transition">
                Editar Aluno
            </a>
            <button class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition">
                Excluir
            </button>
        </div>
    </div>
</div>