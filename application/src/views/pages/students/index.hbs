<div class="bg-white p-6 rounded-lg shadow-sm border">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-semibold text-gray-700">Gestão de Alunos</h2>
        <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium transition">
            + Novo Aluno
        </button>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b">
                    <th class="p-3 text-sm font-semibold text-gray-600">Nome</th>
                    <th class="p-3 text-sm font-semibold text-gray-600">Telefone</th>
                    <th class="p-3 text-sm font-semibold text-gray-600">Status</th>
                    <th class="p-3 text-sm font-semibold text-gray-600 text-right">Ações</th>
                </tr>
            </thead>
            <tbody>
                {{#each students}}
                <tr class="border-b hover:bg-gray-50 transition">
                    <td class="p-3 font-medium text-gray-800">{{this.name}}</td>
                    <td class="p-3 text-gray-600">{{this.phone}}</td>
                    <td class="p-3">
                        {{#if this.isActive}}
                            <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full font-medium">Ativo</span>
                        {{else}}
                            <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full font-medium">Inativo</span>
                        {{/if}}
                    </td>
                    <td class="p-3 text-right">
                        <button class="text-blue-500 hover:text-blue-700 text-sm font-medium">Editar</button>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="4" class="p-6 text-center text-gray-500">Nenhum aluno encontrado.</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>