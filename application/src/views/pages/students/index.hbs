<script type="module" src="/js/modal.js"></script>
<script src="/js/student.js"></script>
<script type="module" src="/js/getData.js"></script>
<script type="module" src="/js/sendData.js"></script>

<div class="flex-1 overflow-y-auto p-4 lg:p-6">
    <div class="space-y-6">
        {{> top tagName="Alunos" tagButton="Novo Aluno" tagId="student-counters" action="populateAndOpen(null, { id: 'student-id', path: 'students', modalId: 'modal-student', fields: { name: 'student-name', phone: 'student-phone' }, checkboxes: { isActive: 'student-active' } })" }}

        <div class="flex flex-col sm:flex-row gap-3">
            <div class="relative flex-1">
                <input id="search-input" placeholder="Buscar aluno..." class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-300 bg-white" value="">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 absolute left-3 top-2.5 text-gray-400">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
            </div>
            <div class="flex gap-2">
                <button id="btn-all" data-filter="all" class="filter-btn px-4 py-2.5 rounded-xl text-sm font-medium capitalize transition-colors bg-green-500 text-white">todos</button>
                <button id="btn-active" data-filter="active" class="filter-btn px-4 py-2.5 rounded-xl text-sm font-medium capitalize transition-colors bg-white border border-gray-200 text-gray-600 hover:bg-gray-50">ativos</button>
                <button id="btn-inactive" data-filter="inactive" class="filter-btn px-4 py-2.5 rounded-xl text-sm font-medium capitalize transition-colors bg-white border border-gray-200 text-gray-600 hover:bg-gray-50">inativos</button>
            </div>
        </div>
        {{> studentList }}
    </div>
</div>

{{> studentModal }}
